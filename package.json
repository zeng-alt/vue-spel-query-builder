{
  "name": "@zeng-alt/vue-spel-query-builder",
  "version": "1.0.0",
  "description": "Vue3 SpEL Query Builder - A visual rule tree and code editor for SpEL expressions",
  "author": "zeng-alt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeng-alt/vue-spel-query-builder.git"
  },
  "bugs": {
    "url": "https://github.com/zeng-alt/vue-spel-query-builder/issues"
  },
  "homepage": "https://github.com/zeng-alt/vue-spel-query-builder#readme",
  "type": "module",
  "keywords": [
    "vue3",
    "spel",
    "query-builder",
    "rule-engine",
    "codemirror",
    "naive-ui"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.esm",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/assets/vue-spel-query-builder.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.lib.config.ts",
    "build:all": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --config vite.config.ts",
    "test:unit": "vitest",
    "build-only": "vite build --config vite.lib.config.ts",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "naive-ui": "^2.44.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.9.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@lezer/highlight": "^1.2.0",
    "@unocss/vite": "^66.6.8",
    "codemirror": "^6.0.1",
    "spel2js": "^0.2.9",
    "unocss": "^66.6.8",
    "vite-plugin-dts": "^5.0.0",
    "vue-codemirror": "^6.1.1"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.8",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "naive-ui": "^2.44.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
